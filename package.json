{
  "name": "agentstd",
  "version": "0.1.0",
  "description": "Standardize hooks, skills, and shared instructions across AI coding agents.",
  "author": "rubichandrap",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rubichandrap/agentstd.git"
  },
  "type": "module",
  "bin": {
    "agentstd": "dist/index.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "dev": "tsx src/cli/index.ts",
    "build": "tsup src/cli/index.ts --format esm --dts --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "prepare": "husky"
  },
  "keywords": [
    "ai",
    "agent",
    "claude",
    "cli",
    "coding",
    "developer-tools"
  ],
  "license": "MIT",
  "dependencies": {
    "commander": "^12.1.0",
    "fs-extra": "^11.2.0",
    "gray-matter": "^4.0.3",
    "picocolors": "^1.1.1",
    "yaml": "^2.6.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.10.0",
    "husky": "^9.1.7",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20.20.0"
  },
  "packageManager": "pnpm@9.15.9+sha512.68046141893c66fad01c079231128e9afb89ef87e2691d69e4d40eee228988295fd4682181bae55b58418c3a253bde65a505ec7c5f9403ece5cc3cd37dcf2531"
}
